---
const groupId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="mdx-tabs" data-group={groupId}>
  <slot />
</div>
<script>
  document.querySelectorAll('.mdx-tabs').forEach((group) => {
    const groupId = group.getAttribute('data-group');
    const inputs = group.querySelectorAll(':scope > .mdx-tab-input');
    inputs.forEach((input, i) => {
      input.setAttribute('name', groupId || 'tabs');
      if (i === 0) input.checked = true;
    });
  });
</script>
<style>
  .mdx-tabs {
    display: flex;
    flex-wrap: wrap;
    margin: 1rem 0;
  }
</style>

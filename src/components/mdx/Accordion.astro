---
interface Props {
  title?: string;
  icon?: string;
  defaultOpen?: boolean;
}
const { title, defaultOpen = false } = Astro.props as Props;
---
<details class="mdx-accordion" open={defaultOpen}>
  <summary class="mdx-accordion-summary">{title}</summary>
  <div class="mdx-accordion-body">
    <slot />
  </div>
</details>
<style>
  .mdx-accordion {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
  }
  .mdx-accordion-summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }
  .mdx-accordion-summary::-webkit-details-marker {
    display: none;
  }
  .mdx-accordion-summary::before {
    content: '▸';
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform 0.15s ease;
  }
  .mdx-accordion[open] > .mdx-accordion-summary::before {
    transform: rotate(90deg);
  }
  .mdx-accordion-body {
    padding-top: 0.75rem;
    font-size: 0.9rem;
  }
</style>

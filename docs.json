{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hyve",
  "colors": {
    "primary": "#000000",
    "light": "#FFFFFF",
    "dark": "#9C9C9C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "installation",
              "configuration"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/gitops",
              "concepts/repositories",
              "concepts/clusters",
              "concepts/workflows",
              "concepts/templates"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/git-management",
              "guides/cluster-management",
              "guides/workflow-management",
              "guides/template-management",
              "guides/kubeconfig-management",
              "guides/credentials"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "workflows/overview",
              "workflows/requirements",
              "workflows/variables",
              "workflows/validation",
              "workflows/examples"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/git",
              "cli/cluster",
              "cli/workflow",
              "cli/template",
              "cli/kubeconfig",
              "cli/config"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/your-org/hyve",
          "icon": "github"
        },
        {
          "anchor": "Community",
          "href": "https://discord.gg/your-discord",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@hyve.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/home"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/your-org/hyve"
    }
  }
}

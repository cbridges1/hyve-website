{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hyve",
  "colors": {
    "primary": "#000000",
    "light": "#FFFFFF",
    "dark": "#9C9C9C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "pages": ["index"]
      },
      {
        "tab": "Documentation",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/quickstart",
              "docs/installation",
              "docs/configuration"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "docs/concepts/modules",
              "docs/concepts/clusters",
              "docs/concepts/templates",
              "docs/concepts/workflows",
              "docs/concepts/resources",
              "docs/concepts/repositories",
              "docs/concepts/gitops"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "docs/guides/git-management",
              "docs/guides/cluster-management",
              "docs/guides/workflow-management",
              "docs/guides/resource-management",
              "docs/guides/template-management",
              "docs/guides/kubeconfig-management",
              "docs/guides/cicd",
              "docs/guides/argocd",
              "docs/guides/server-mode"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "docs/cli/overview",
              "docs/cli/cluster",
              "docs/cli/module",
              "docs/cli/template",
              "docs/cli/workflow",
              "docs/cli/git",
              "docs/cli/kubeconfig",
              "docs/cli/tui",
              "docs/cli/run"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/cbridges1/hyve",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/cbridges1/hyve"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/docs/quickstart"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cbridges1/hyve"
    }
  }
}
